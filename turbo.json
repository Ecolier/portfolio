{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**", ".output/**"]
    },
    "generate:types": {
      "outputs": ["../../packages/types/generated.ts"]
    },
    "dev": {
      "dependsOn": ["@portfolio/cms#generate:types"],
      "cache": false,
      "persistent": true
    }
  }
}
